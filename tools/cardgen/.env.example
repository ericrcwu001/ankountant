# Copy to .env (gitignored). Required only for LIVE runs.
# Tests and the offline pipeline run WITHOUT any key.
# Paste your FULL key after the = sign (it already begins with sk-; do NOT add another sk-).
OPENAI_API_KEY=

# Optional overrides (defaults shown):
# CARDGEN_GEN_MODEL=gpt-5-mini          # generator (reasoning model; API is model-aware)
# CARDGEN_GEN_FALLBACK_MODEL=gpt-4o     # used if the primary model 404s / no access
# CARDGEN_REASONING_EFFORT=low          # gpt-5*/o* only (minimal|low|medium|high)
# CARDGEN_PROMPT_VERSION=v2             # v2 adds the decline rule ({"skip": true})
# CARDGEN_EMBED_MODEL=text-embedding-3-small
# CARDGEN_RERANK=1                      # hybrid-arm reranker (0 to disable)
# CARDGEN_RERANK_MODEL=gpt-4o-mini
# CARDGEN_CONCURRENCY=24                # live generation concurrency (fan-out)
# CARDGEN_EMBED_CONCURRENCY=8
# CARDGEN_BATCH_API=0                   # 1 -> use the OpenAI Batch API for generation
# CARDGEN_JUDGE_MODE=full              # full|audit (audit judges a sample + self-check gates the rest)
# CARDGEN_JUDGE_PARALLELISM=8           # parallel Cursor judge subagents per wave
# CARDGEN_OFFLINE=1                    # force deterministic offline backends even if a key is set

# Tier-B (copyrighted, personal-use) corpus is agent/MCP-driven (annas-mcp):
# ANNAS_SECRET_KEY=...
# ANNAS_DOWNLOAD_PATH=...
